{
  "name": "vscode-skel",
  "displayName": "Skel",
  "description": "Syntax highlighting and symbol navigation for .skel files.",
  "version": "0.0.2",
  "publisher": "yorun",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yorun-ai/skelc.git",
    "directory": "tool/vscode-skel"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "skel",
        "aliases": [
          "Skel",
          "skel"
        ],
        "extensions": [
          ".skel"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "skel",
        "scopeName": "source.skel",
        "path": "./syntaxes/skel.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Skel Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/skel-dark-color-theme.json"
      }
    ]
  },
  "scripts": {
    "check": "node ./scripts/check.js"
  },
  "devDependencies": {}
}
